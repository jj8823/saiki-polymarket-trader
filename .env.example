# Polymarket Trader - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# APPLICATION
# =============================================================================
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection (used by Docker Compose and application)
POSTGRES_USER=polymarket
POSTGRES_PASSWORD=polymarket
POSTGRES_DB=polymarket

# Full database URL (for local development without Docker)
DATABASE_URL=postgresql+asyncpg://polymarket:polymarket@localhost:5432/polymarket

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379

# Celery configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# POLYMARKET API
# =============================================================================
# Your Polygon wallet private key (without 0x prefix)
# IMPORTANT: Never commit your private key to version control!
POLYMARKET_PRIVATE_KEY=

# Your wallet address (funder address for orders)
POLYMARKET_FUNDER_ADDRESS=

# API credentials (obtained from CLOB client)
# These can be derived from your private key or set manually
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# =============================================================================
# FRONTEND
# =============================================================================
# API URL for frontend (Vite environment variable)
VITE_API_URL=http://localhost:8000/api/v1

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================
# CORS origins (comma-separated list)
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database connection pool settings
# DATABASE_POOL_SIZE=5
# DATABASE_MAX_OVERFLOW=10

# Polymarket API endpoints (defaults are usually fine)
# CLOB_API_URL=https://clob.polymarket.com
# GAMMA_API_URL=https://gamma-api.polymarket.com
# CHAIN_ID=137
